    {
      "parameters": {
        "jsCode": "const text = $node[\"HTTP Request2\"].json[\"data\"]; \n\nconst match = text.match(/var\\s+details\\s*=\\s*(\\[[\\s\\S]*?\\]);/);\nif (!match) {\n  throw new Error(\"details JSON bulunamadı.\");\n}\n\nconst detailsArray = JSON.parse(match[1]);\nconst d = detailsArray[0];\n\nreturn [\n  {\n    json: {\n      ParselGuid: d.ParselGuid,\n      AdaNo: d.AdaNo,\n      ParselNo: d.ParselNo,\n      ParselAlani: d.TapuAlan,\n      Kaks: d.Kaks,\n      FonksiyonAdi: d.FonksiyonAdi || d.Konut,\n      KatAdedi: d.KatAdedi,\n      Mahalle: d.TapuMahalleAd,\n      Ilce: d.TapuIlceAd,\n      Il: d.TapuIlAd,\n      // Çekme Mesafeleri: Sistemde varsa al, yoksa varsayılanı (5, 4, 4) ata\n      OnCekme: d.OnBahce ,\n      YanCekme: d.YanBahce ,\n      ArkaCekme: d.ArkaBahce || \"4\"\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        352
      ],
      "id": "10922440-4869-4a0f-b09a-b6165d6d6fbe",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// AI Agent'ın ürettiği metni alıyoruz\nconst reportText = $node[\"AI Agent\"].json.output;\n\n// Regex ile m2 fiyatı ve proje değerini ayıklıyoruz\nconst m2FiyatMatch = reportText.match(/(\\d{1,3}(?:\\.\\d{3})*)\\s*TL\\/m²/);\nconst projeDegerMatch = reportText.match(/(\\d{1,3}(?:\\.\\d{3})*(?:,\\d+)?)\\s*TL(?!\\/m²)/g);\nconst sonTlDegeri = projeDegerMatch ? projeDegerMatch[projeDegerMatch.length - 1] : \"Hesaplanamadı\";\n\nreturn {\n  // Ada ve Parsel bilgisini ana veri düğümünden alıyoruz\n  ada_parsel: $node[\"Code in JavaScript\"].json.AdaNo + \"/\" + $node[\"Code in JavaScript\"].json.ParselNo,\n  imar_durumu: $node[\"Code in JavaScript\"].json.Kaks, // Emsal bilgisini buraya yazıyoruz\n  m2_fiyat: m2FiyatMatch ? m2FiyatMatch[1] : \"Bulunamadı\",\n  proje_degeri: sonTlDegeri,\n  tam_rapor: reportText\n};"
      },
