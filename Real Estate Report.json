    {
      "parameters": {
        "jsCode": "// İlk HTTP Request'ten gelen HTML verisini alıyoruz\nconst htmlContent = $node[\"HTTP Request1\"].json[\"data\"]; \n\n// Regex ile ParselBelgeGetir(&#x27;...&#x27;) içindeki ID'yi buluyoruz\nconst regex = /ParselBelgeGetir\\(&#x27;([^&]+)&#x27;\\)/;\nconst match = htmlContent.match(regex);\n\n// Eğer eşleşme varsa ID'yi, yoksa null döndürüyoruz\nreturn {\n  parsel_guid: match ? match[1] : null\n};"
      },
